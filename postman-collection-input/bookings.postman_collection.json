                  "});",
                  "",
                  "pm.test('TC-302: Response has error message', () => {",
                  "    const json = pm.response.json();",
                  "    const msg = json.error || json.message;",
                  "    pm.expect(msg).to.be.a('string').and.to.not.be.empty;",
                  "});",
                  "",
                  "pm.test('TC-302: Error relates to booking validation (quantity or seats)', () => {",
                  "    const json = pm.response.json();",
                  "    // API validates quantity <= 10 before seat-availability check,",
                  "    // so quantity=100 hits quantity validation first",
                  "    const allText = JSON.stringify(json).toLowerCase();",
                  "    pm.expect(allText.includes('seat') || allText.includes('insufficient') || allText.includes('quantity')).to.be.true;",
                  "});",
                  "",
                  "// Fix #7: Content-Type header",
                  "pm.test('Content-Type is application/json', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "// Fix #1: response time missing from all error requests",
                  "pm.test('Response time under 1000ms', () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ]
