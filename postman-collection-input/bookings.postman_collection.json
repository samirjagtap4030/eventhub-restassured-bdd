{
  "info": {
    "name": "Bookings",
    "_postman_id": "bk000001-0001-0001-0001-000000000001",
    "description": "EventHub Bookings API — 16 requests: Setup, Happy Path, Error Scenarios, Security",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
