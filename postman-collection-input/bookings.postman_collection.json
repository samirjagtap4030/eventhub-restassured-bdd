    {
      "name": "Happy Path",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-102: Status is 201', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('TC-102: Booking ref matches pattern ^[A-Z]-[A-Z0-9]{6}$', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.bookingRef).to.match(/^[A-Z]-[A-Z0-9]{6}$/);",
                  "});",
                  "",
                  "pm.test('TC-106: Booking ref first letter matches event title first letter', () => {",
                  "    const json = pm.response.json();",
                  "    const eventTitle = pm.environment.get('eventTitle');",
                  "    pm.expect(json.data.bookingRef.charAt(0)).to.eql(eventTitle.charAt(0).toUpperCase());",
                  "});",
                  "",
                  "pm.test('TC-106: Total price equals quantity x event price', () => {",
                  "    const json = pm.response.json();",
                  "    const eventPrice = parseFloat(pm.environment.get('eventPrice'));",
                  "    pm.expect(parseFloat(json.data.totalPrice)).to.eql(2 * eventPrice);",
                  "});",
                  "",
                  "pm.test('TC-102: Status field is confirmed', () => {",
                  "    pm.expect(pm.response.json().data.status).to.eql('confirmed');",
                  "});",
                  "",
                  "// Fix #2: variable-saving in its own dedicated test block, not mixed into an assertion",
                  "pm.test('Save booking ID and ref for downstream requests', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.id).to.be.a('number');",
                  "    pm.environment.set('bookingId', String(json.data.id));",
                  "    pm.environment.set('bookingRef', json.data.bookingRef);",
                  "});",
                  "",
                  "// Fix #7: Content-Type header validation",
                  "pm.test('Content-Type is application/json', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "// Fix #8: JSON schema validation via tv4",
                  "const bookingSchema = {",
                  "    type: 'object',",
                  "    required: ['data'],",
                  "    properties: {",
                  "        data: {",
                  "            type: 'object',",
                  "            required: ['id', 'bookingRef', 'customerName', 'customerEmail', 'customerPhone', 'quantity', 'totalPrice', 'status'],",
                  "            properties: {",
                  "                id:            { type: 'number' },",
                  "                bookingRef:    { type: 'string' },",
                  "                customerName:  { type: 'string' },",
                  "                customerEmail: { type: 'string' },",
                  "                customerPhone: { type: 'string' },",
                  "                quantity:      { type: 'number' },",
                  "                totalPrice:    { type: ['number', 'string'] },",
                  "                status:        { type: 'string' }",
                  "            }",
                  "        }",
                  "    }",
                  "};",
                  "pm.test('Response matches booking schema', () => {",
                  "    pm.expect(tv4.validate(pm.response.json(), bookingSchema)).to.be.true;",
                  "});",
                  "",
                  "pm.test('Response time under 1000ms', () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ]
              }
            }
