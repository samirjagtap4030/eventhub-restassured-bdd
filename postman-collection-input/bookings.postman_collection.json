            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Fix #4: verify seat count reduced by booking quantity (business-rules.md §6)",
                  "pm.test('Status is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Available seats reduced by booking quantity', () => {",
                  "    const json = pm.response.json();",
                  "    const seatsBefore = parseInt(pm.environment.get('seatsBefore'));",
                  "    const bookingQty  = parseInt(pm.environment.get('bookingQty'));",
                  "    pm.expect(json.data.availableSeats).to.eql(seatsBefore - bookingQty);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
