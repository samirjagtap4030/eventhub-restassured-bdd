  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Auto-register admin so collection works on a fresh database",
                  "pm.sendRequest({",
                  "    url: `${pm.environment.get('baseUrl')}/api/auth/register`,",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json' },",
                  "    body: {",
                  "        mode: 'raw',",
                  "        raw: JSON.stringify({",
                  "            email: pm.environment.get('adminEmail'),",
                  "            password: pm.environment.get('adminPassword')",
                  "        })",
                  "    }",
                  "}, (err, res) => {",
                  "    if (err) { console.log('Register skipped:', err.message); return; }",
                  "    console.log('Register status:', res.status(), '(409 = already exists, OK)');",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Token is string and not empty', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.token).to.be.a('string').and.to.not.be.empty;",
                  "    pm.environment.set('authToken', json.token);",
                  "    pm.environment.set('userId', String(json.user.id));",
                  "});",
                  "",
                  "pm.test('Response time under 1000ms', () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{adminEmail}}\",\"password\":\"{{adminPassword}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Create Event",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const ts = Date.now();",
                  "pm.variables.set('uniqueTitle', `Test Event ${ts}`);",
                  "pm.variables.set('futureDate', new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Event data has required fields and correct types', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.id).to.be.a('number');",
                  "    pm.expect(json.data.title).to.be.a('string').and.to.not.be.empty;",
                  "    pm.expect(parseFloat(json.data.price)).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Save event variables for later requests', () => {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('eventId', String(json.data.id));",
                  "    pm.environment.set('eventTitle', json.data.title);",
                  "    pm.environment.set('eventPrice', String(parseFloat(json.data.price)));",
                  "    // Fix #4: save seat count before booking for seat-reduction assertion (business-rules.md §6)",
                  "    const seats = json.data.availableSeats !== undefined ? json.data.availableSeats : json.data.totalSeats;",
                  "    pm.environment.set('seatsBefore', String(seats));",
                  "    pm.environment.set('bookingQty', '2');",
                  "});",
                  "",
                  "pm.test('Response time under 1000ms', () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"title\":\"{{uniqueTitle}}\",\"category\":\"Conference\",\"venue\":\"Tech Park\",\"city\":\"Bangalore\",\"eventDate\":\"{{futureDate}}\",\"price\":500,\"totalSeats\":50}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/events",
              "host": ["{{baseUrl}}"],
              "path": ["api", "events"]
            }
          }
        }
      ]
