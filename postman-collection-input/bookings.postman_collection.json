        },
        {
          "name": "Cross-user GET Booking",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const baseUrl = pm.environment.get('baseUrl');",
                  "const ts = Date.now();",
                  "const secondEmail = `second-${ts}@example.com`;",
                  "const secondPassword = 'Password123!';",
                  "const futureDate = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString();",
                  "",
                  "// Fix #5: reset setup guard at start so a stale 'true' never gives false confidence",
                  "pm.environment.set('crossUserSetupOk', 'false');",
                  "",
                  "// Step 1: Register second user",
                  "pm.sendRequest({",
                  "    url: `${baseUrl}/api/auth/register`,",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json' },",
                  "    body: { mode: 'raw', raw: JSON.stringify({ email: secondEmail, password: secondPassword }) }",
                  "}, (err1, res1) => {",
                  "    if (err1) { console.error('Register failed:', err1); return; }",
                  "    const regJson = res1.json();",
                  "    const secondToken = regJson.token;",
                  "    if (!secondToken) { console.error('No token from register:', JSON.stringify(regJson)); return; }",
                  "    pm.environment.set('secondUserToken', secondToken);",
                  "",
                  "    // Step 2: Second user creates their own event (sandbox isolation)",
                  "    pm.sendRequest({",
                  "        url: `${baseUrl}/api/events`,",
                  "        method: 'POST',",
                  "        header: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${secondToken}` },",
                  "        body: {",
                  "            mode: 'raw',",
                  "            raw: JSON.stringify({ title: `Second Event ${ts}`, category: 'Conference', venue: 'Test Venue', city: 'Bangalore', eventDate: futureDate, price: 100, totalSeats: 10 })",
                  "        }",
                  "    }, (err2, res2) => {",
                  "        if (err2) { console.error('Create event failed:', err2); return; }",
                  "        const evJson = res2.json();",
                  "        if (!evJson.data || !evJson.data.id) { console.error('Create event bad response:', JSON.stringify(evJson)); return; }",
                  "        const secondEventId = evJson.data.id;",
                  "",
                  "        // Step 3: Second user books their own event",
                  "        pm.sendRequest({",
                  "            url: `${baseUrl}/api/bookings`,",
                  "            method: 'POST',",
                  "            header: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${secondToken}` },",
                  "            body: {",
                  "                mode: 'raw',",
                  "                raw: JSON.stringify({ eventId: secondEventId, customerName: 'Second User', customerEmail: secondEmail, customerPhone: '9876543210', quantity: 1 })",
                  "            }",
                  "        }, (err3, res3) => {",
                  "            if (err3) { console.error('Booking failed:', err3); return; }",
                  "            const bJson = res3.json();",
                  "            if (!bJson.data || !bJson.data.id) { console.error('Booking bad response:', JSON.stringify(bJson)); return; }",
                  "            pm.environment.set('secondUserBookingId', String(bJson.data.id));",
                  "            // Fix #5: only mark OK after all 3 steps succeed",
                  "            pm.environment.set('crossUserSetupOk', 'true');",
                  "        });",
                  "    });",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Fix #5: verify pre-request setup chain succeeded — prevents false-positive 403",
                  "pm.test('Pre-request cross-user setup succeeded', () => {",
                  "    pm.expect(pm.environment.get('crossUserSetupOk')).to.eql('true');",
                  "});",
                  "",
                  "pm.test('TC-201: Status is 403', () => {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "",
                  "pm.test('TC-201: Response has error message', () => {",
                  "    const json = pm.response.json();",
                  "    const msg = json.error || json.message;",
                  "    pm.expect(msg).to.be.a('string').and.to.not.be.empty;",
                  "});",
                  "",
                  "// Fix #7: Content-Type header",
                  "pm.test('Content-Type is application/json', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "// Fix #1: response time",
                  "pm.test('Response time under 1000ms', () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/bookings/{{secondUserBookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings", "{{secondUserBookingId}}"]
            }
          }
        }
